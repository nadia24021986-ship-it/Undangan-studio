# Salin nilai ini ke Vercel: Project Settings -> Environment Variables
# Jangan commit file .env asli (berisi kunci) ke GitHub publik.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=isi-dengan-anon-public-key-dari-supabase

# Kata sandi untuk masuk ke Dashboard Admin (halaman "/").
# Ganti dengan kata sandi kamu sendiri, jangan pakai contoh ini.
VITE_ADMIN_PASSWORD=ganti-dengan-password-rahasia
